 /*
 * gCNV & CNVkit PON Builder - Nextflow Config（DGX-2 專用）
 */

def currentUser = System.getenv('USER') ?: 'unknown'

singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = "/datalake_Intermediate/pipeline/nextflow_containers"
    runOptions = "--nv --bind /datalake_Intermediate,/datalake_Raw,/raid --env PYTENSOR_FLAGS=compiledir=/raid/DGM/pytensor_cache/${currentUser}"
}

params {
    input_csv   = null
    pon_out_dir = "/datalake_Intermediate/pipeline/reference/hg38/gcnv_pon"
    out_dir     = "/datalake_Intermediate/pipeline/nextflow_output/pon_preprocessing"
    ref_dir              = "/datalake_Intermediate/pipeline/reference/hg38"
    sif_dir              = "/datalake_Intermediate/pipeline/nextflow_containers"
    fq2bam_num_gpus = 1
    fasta                = "${params.ref_dir}/Homo_sapiens_assembly38.fasta"
    dbsnp                = "${params.ref_dir}/Homo_sapiens_assembly38.dbsnp138.vcf.gz"
    known_indels         = "${params.ref_dir}/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz"
    known_indels2        = "${params.ref_dir}/Homo_sapiens_assembly38.known_indels.vcf.gz"
    known_snps           = "${params.ref_dir}/1000G_phase1.snps.high_confidence.hg38.vcf.gz"
    wes_targets          = "${params.ref_dir}/Illumina_Exome_TargetedRegions_v1.2.hg38.bed"
    blacklist_bed        = "${params.ref_dir}/hg38_clinical_blacklist.main.bed"
    mappability_bed      = "${params.ref_dir}/hg38_k100_umap_merged.bed.gz"
    segdup_bed           = "${params.ref_dir}/hg38_seg_dup.bed.gz"
    contig_ploidy_priors = "${params.ref_dir}/contig_ploidy_prior_hg38.tsv"
    fq2bam_args          = "--low-memory --gpusort --gpuwrite"
    htvc_args            = ""
    seq_type             = "WES"
    use_gpu_lock = true
}

process {
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 2

    withLabel: process_low    { cpus = 4;  memory = 8.GB  }
    withLabel: process_medium { cpus = 16; memory = 32.GB }
    withLabel: process_high   { cpus = 48; memory = 64.GB }
    withLabel: process_gpu {
        // accelerator 只是標記，實際 GPU 分配由 gpu_lock.sh 處理
        accelerator = [request: 1, type: 'nvidia']
        // 6 張 V100 同時各跑一個 FQ2BAM（單卡 + --low-memory）
        maxForks    = 6
    }

    withName: 'FASTP'               { 
        container = "${params.sif_dir}/fastp_1.3.0.sif" 
    }
    withName: 'PARABRICKS_FQ2BAM'   { 
        container = "${params.sif_dir}/parabricks_4.4.0.sif" 
        // WES FQ2BAM 實測約 38GB VRAM，--low-memory 壓到 16GB 以下
        // CPU 記憶體：WES 比 WGS 少很多，64GB 已足夠
        memory    = 64.GB
        cpus      = 16
    }
    withName: 'PREP_GATK_INTERVALS' { container = "${params.sif_dir}/gatk_4.6.2.0.sif" }
    withName: 'PREP_CNVKIT_BEDS'    { container = "${params.sif_dir}/cnvkit_0.9.12.sif" }
    withName: 'COLLECT_GATK_COUNTS' { 
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        maxForks  = 20 
    }
    withName: 'COLLECT_CNVKIT_COV'  { 
        container = "${params.sif_dir}/cnvkit_0.9.12.sif"
        maxForks  = 20
    }
    withName: 'CNVKIT_REFERENCE'    { container = "${params.sif_dir}/cnvkit_0.9.12.sif" }
    withName: 'FILTER_INTERVALS'    { container = "${params.sif_dir}/gatk_4.6.2.0.sif" }
    withName: 'SCATTER_INTERVALS'   { container = "${params.sif_dir}/gatk_4.6.2.0.sif" }

    withName: 'PLOIDY_COHORT' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        memory    = { task.attempt > 1 ? 256.GB : 128.GB }
    }
    withName: 'GCNV_COHORT' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        memory    = { task.attempt > 1 ? 512.GB : 300.GB }
        time      = '120h'
    }
}

def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
report   { enabled = true; overwrite = true; file = "${params.pon_out_dir}/pon_report_${trace_timestamp}.html" }
timeline { enabled = true; overwrite = true; file = "${params.pon_out_dir}/pon_timeline_${trace_timestamp}.html" }
trace    { enabled = true; overwrite = true; file = "${params.pon_out_dir}/pon_trace_${trace_timestamp}.txt" }