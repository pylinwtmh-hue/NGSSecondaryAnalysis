def currentUser = System.getenv('USER') ?: 'unknown'

profiles {

    // --- 環境 A: 本機開發環境 ---
    // CPU: R9 9950X 16c/32t, RAM: 128GB, GPU: RTX PRO 6000 96GB VRAM
    local {
        params {
            ref_dir               = "/scratch/pylin1991/GenomicReference_Cache/hg38"
            sif_dir               = "/data/pylin1991/nf-containers"
            out_dir               = "/scratch/pylin1991/Pipeline_test"
            gpu_ids               = "0"
            parabricks_sif_name   = "parabricks_4.7.0-1.sif"
            fq2bam_args           = "--memory-limit 100 --bwa-normalized-queue-capacity 5 --gpusort --gpuwrite"
            fq2bam_num_gpus       = 1
            dv_num_gpus           = 1
            htvc_num_gpus         = 1
            htvc_args             = ""
            use_gpu_lock          = false
        }
        singularity {
            runOptions = "--nv --bind /home,/data,/scratch --env CUDA_VISIBLE_DEVICES=${params.gpu_ids}"
        }
        process {
            withLabel: process_low    { cpus = 2;  memory = 4.GB   }
            withLabel: process_medium { cpus = 8;  memory = 16.GB  }
            withLabel: process_high   { cpus = 16; memory = 16.GB  }
            withLabel: process_gpu {
                clusterOptions = '--gpus "device=0"'
                maxForks       = 1
                errorStrategy  = 'retry'
                maxRetries     = 1
            }
        }
    }

    // --- 環境 B: DGM Server ---
    // CPU: Xeon w7-3565X 32c/64t, RAM: 125GB, GPU: RTX 2000 Ada 16GB VRAM
    // --low-memory 因 VRAM 只有 16GB，避免 Parabricks OOM
    dgm {
        params {
            ref_dir               = "/home/datalake_Intermediate/pipeline/reference/hg38"
            sif_dir               = "/home/datalake_Intermediate/pipeline/nextflow_containers"
            out_dir               = "/home/datalake_Intermediate/pipeline/nextflow_output"
            gpu_ids               = "0"
            parabricks_sif_name   = "parabricks_4.7.0-1.sif"
            fq2bam_args           = "--low-memory --memory-limit 100"
            fq2bam_num_gpus       = 1
            dv_num_gpus           = 1
            htvc_num_gpus         = 1
            htvc_args             = "--htvc-low-memory"
            use_gpu_lock          = false        
        }
        singularity {
            runOptions = "--nv --bind /home --env CUDA_VISIBLE_DEVICES=${params.gpu_ids} --env PYTENSOR_FLAGS=compiledir=/home/pipeline/pytensor_cache/${currentUser}"

        }
        process {
            withLabel: process_low    { cpus = 2;  memory = 4.GB   }
            withLabel: process_medium { cpus = 8;  memory = 16.GB  }
            withLabel: process_high   { cpus = 32; memory = 16.GB  }
            withLabel: process_gpu {
                clusterOptions = '--gpus "device=0"'
                maxForks       = 1
                errorStrategy  = 'retry'
                maxRetries     = 1
            }
        }
    }

    // --- 環境 C: DGX-2 ---
    // CPU: Xeon Platinum 8168 48c/96t, RAM: 1.5TB, GPU: V100 × 6（GPU 10-15，各 32GB）
    // RAM 充裕，可同時跑多個樣本
    dgx {
        params {
            ref_dir               = "/datalake_Intermediate/pipeline/reference/hg38"
            sif_dir               = "/datalake_Intermediate/pipeline/nextflow_containers"
            out_dir               = "/datalake_Intermediate/pipeline/nextflow_output"
            parabricks_sif_name   = "parabricks_4.4.0.sif"
            fq2bam_args           = "--low-memory --gpusort --gpuwrite"
            fq2bam_num_gpus       = 1
            dv_num_gpus           = 1
            htvc_num_gpus         = 1
            htvc_args             = ""
            use_gpu_lock          = true
        }
        singularity {
            // 拿掉 --env CUDA_VISIBLE_DEVICES，信任gpu_lock
            runOptions = "--nv --bind /datalake_Intermediate,/datalake_Raw,/raid --env PYTENSOR_FLAGS=compiledir=/raid/DGM/pytensor_cache/${currentUser}"
        }
        process {
            withLabel: process_low    { cpus = 4;   memory = 8.GB   }
            withLabel: process_medium { cpus = 16;  memory = 32.GB  }
            withLabel: process_high   { cpus = 48;  memory = 64.GB  }
            withLabel: process_gpu {
                // 告訴 Nextflow 這個 Process 要獨佔 1 張 GPU
                accelerator    = [request: 1, type: 'nvidia']
                // 最多同時平行跑 6 個任務（有 6 張卡）
                maxForks       = 6
            }
        }
    }
    // --- 環境 C2: DGX-2 單樣本加速模式 ---
    // 6 張 V100 全部給單一樣本，適合單樣本情境
    // fq2bam 約 40 分鐘（vs 標準模式 3 小時）
    dgx_single {
        params {
            ref_dir               = "/datalake_Intermediate/pipeline/reference/hg38"
            sif_dir               = "/datalake_Intermediate/pipeline/nextflow_containers"
            out_dir               = "/datalake_Intermediate/pipeline/nextflow_output"
            parabricks_sif_name   = "parabricks_4.4.0.sif"
            fq2bam_args           = "--low-memory --gpusort --gpuwrite"
            fq2bam_num_gpus       = 6
            dv_num_gpus           = 6
            htvc_num_gpus         = 6
            htvc_args             = ""
            use_gpu_lock          = true
        }
        singularity {
            runOptions = "--nv --bind /datalake_Intermediate,/datalake_Raw,/raid --env PYTENSOR_FLAGS=compiledir=/raid/DGM/pytensor_cache/${currentUser}"
        }
        process {
            withLabel: process_low    { cpus = 4;   memory = 8.GB   }
            withLabel: process_medium { cpus = 16;  memory = 32.GB  }
            withLabel: process_high   { cpus = 48;  memory = 64.GB  }
            withLabel: process_gpu {
                accelerator = [request: 6, type: 'nvidia']
                maxForks    = 1  // 同時只跑一個樣本，全部 6 張卡給它
            }
        }
    }
}

// --- Singularity 通用設定 ---
singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = "${params.sif_dir}"
}

// --- 參數預設值 ---
params {
    input_csv  = null
    seq_type   = "WGS"

    // 選用工具開關（全部預設 OFF）
    //   ROH 不納入評鑑，預設不跑。--run_roh 用 bcftools roh（MIT/GPL，可商用）；
    //   --run_automap 用 AutoMap（無公開授權，僅非商用/研究）。
    //   Manta / ExpansionHunter 為非商用授權，預設 OFF。
    run_manta           = false
    run_expansionhunter = false
    run_roh             = true
    run_automap         = false

    // WES gCNV Panel of Normals（PON）相關參數
    // 由 Part 4 的 PON 建立 pipeline 產生
    // WGS 或未啟用 gCNV 時不使用
    run_gcnv              = false
    pon_root              = "${params.ref_dir}/gcnv_pon"

    // GATK gCNV 專用 (WES)：路徑由 pon_root 推導，各 profile 只需設定 ref_dir
    gcnv_pon_dir          = "${params.pon_root}/filtered.interval_list"
    gcnv_model_dir        = "${params.pon_root}/gcnv_model/shards"
    gcnv_ploidy_model_dir = "${params.pon_root}/gcnv_model/ploidy_model"
    contig_ploidy_priors  = "${params.ref_dir}/contig_ploidy_prior_hg38.tsv"

    // CNVkit 專用
    cnvkit_pon            = "${params.pon_root}/cnvkit_reference/cnvkit_pooled_reference.cnn" 

    fasta_name         = "Homo_sapiens_assembly38.fasta"
    dbsnp_name         = "Homo_sapiens_assembly38.dbsnp138.vcf.gz"
    known_indels_name  = "Mills_and_1000G_gold_standard.indels.hg38.vcf.gz"
    known_indels2_name = "Homo_sapiens_assembly38.known_indels.vcf.gz"
    known_snps_name    = "1000G_phase1.snps.high_confidence.hg38.vcf.gz"
    hapmap_name        = "hapmap_3.3.hg38.vcf.gz"
    omni_name          = "1000G_omni2.5.hg38.vcf.gz"
    axiom_name         = "Axiom_Exome_Plus.genotypes.all_populations.poly.hg38.vcf.gz"
    interval_name      = "wgs_calling_regions.hg38.interval_list"

    fasta         = "${params.ref_dir}/${params.fasta_name}"
    dbsnp         = "${params.ref_dir}/${params.dbsnp_name}"
    known_indels  = "${params.ref_dir}/${params.known_indels_name}"
    known_indels2 = "${params.ref_dir}/${params.known_indels2_name}"
    known_snps    = "${params.ref_dir}/${params.known_snps_name}"
    hapmap        = "${params.ref_dir}/${params.hapmap_name}"
    omni          = "${params.ref_dir}/${params.omni_name}"
    axiom         = "${params.ref_dir}/${params.axiom_name}"
    intervals     = "${params.ref_dir}/${params.interval_name}"

    // Delly SV exclude list
    delly_excl = "${params.ref_dir}/human.hg38.excl.tsv"

    // GangSTR TR reference（替代 ExpansionHunter）
    gangstr_regions_wgs = "${params.ref_dir}/gangstr_hg38_ver17.bed"
    gangstr_regions_wes = "${params.ref_dir}/gangstr_hg38_ver17_WES.bed"

    // ExpansionHunter variant catalog（選用，--run_expansionhunter 時使用）
    str_catalog = "${params.ref_dir}/variant_catalog.json"

    // WES Capture Kit Target Regions
    // Illumina Exome Panel v1.2 (CEX)，對應 Cat. No. 15050026
    wes_targets = "${params.ref_dir}/Illumina_Exome_TargetedRegions_v1.2.hg38.bed"

    // WGS alignment qc
    autosome_bed = "${params.ref_dir}/hg38_autosome_primary.bed"

    // Mitochondria reference
    chrM_only_fasta    = "${params.ref_dir}/chrM/chrM_only.fasta"
    chrM_shifted_fasta = "${params.ref_dir}/chrM/chrM_shifted.fasta"
    chrM_shift_back    = "${params.ref_dir}/chrM/chrM_shift_back.chain"
    chrM_blacklist     = "${params.ref_dir}/chrM/blacklist_sites.hg38.chrM.bed"
}

// --- Process 資源與容器對應 ---
process {
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 2

    // 預設 label 資源（各 profile 可覆寫）
    withLabel: process_low    { cpus = 2;  memory = 4.GB  }
    withLabel: process_medium { cpus = 8;  memory = 16.GB }
    withLabel: process_high   { cpus = 16; memory = 16.GB }

    // 容器對應
    withName: 'FASTP'         { container = "${params.sif_dir}/fastp_1.3.0.sif" }
    withName: 'SAMTOOLS.*'    { container = "${params.sif_dir}/samtools_1.23.1.sif" }
    withName: 'BCFTOOLS.*'    { container = "${params.sif_dir}/bcftools_1.23.1.sif" }
    withName: 'BGZIP_VCF'     { container = "${params.sif_dir}/bcftools_1.23.1.sif" }
    withName: 'MOSDEPTH'      { container = "${params.sif_dir}/mosdepth_0.3.13.sif" }
    withName: 'MULTIQC'       { container = "${params.sif_dir}/multiqc_1.33.sif" }
    withName: 'DELLY.*'        { container = "${params.sif_dir}/delly_1.7.3.sif" }
    withName: 'CNVKIT.*'      { container = "${params.sif_dir}/cnvkit_0.9.12.sif" }
    withName: 'AUTOMAP'       { container = "${params.sif_dir}/automap_1.3.sif" }
    withName: 'EXPANSION.*'   { container = "${params.sif_dir}/expansionhunter_5.0.0.sif" }
    withName: 'MANTA.*'       { container = "${params.sif_dir}/manta_1.6.0.sif" }

    // GATK 系列：個別設定記憶體（實測值 × 1.5 倍緩衝）
    // 注意：withName 優先級高於 withLabel，順序從下往上覆寫
    // GATK.* 是 fallback，VQSR/MITO 個別設定會覆寫這個
    withName: 'GATK.*' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        memory    = { task.attempt > 1 ? 12.GB : 8.GB }
    }
    withName: 'GATK_VQSR_SNP' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        cpus      = 4
        memory    = { task.attempt > 1 ? 18.GB : 12.GB }
    }
    withName: 'GATK_VQSR_INDEL' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        cpus      = 4
        memory    = { task.attempt > 1 ? 14.GB : 10.GB }
    }
    // gCNV Case Mode processes
    withName: 'GATK_COLLECT_READ_COUNTS' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        memory    = { task.attempt > 1 ? 16.GB : 8.GB }
    }
    withName: 'GATK_GERMLINE_CNV_CASE' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        // 「切塊平行運算」，每個碎塊運算量極小
        // 將記憶體降至 16GB，可讓 DGX 同時平行處理數十個碎塊，速度極大化！
        memory    = { task.attempt > 1 ? 32.GB : 16.GB }
        cpus      = 4
    }
    withName: 'GATK_POSTPROCESS_CNV' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        memory    = { task.attempt > 1 ? 32.GB : 16.GB }
    }

    // Parabricks GPU processes：個別設定記憶體（實測值 × 1.1 倍）
    withName: 'PARABRICKS_FQ2BAM' {
        container = "${params.sif_dir}/${params.parabricks_sif_name}"
        cpus      = 16
        memory    = 120.GB
        // 注意：fq2bam 實測 114 GB（30x WGS），是所有 process 中最大的
    }
    withName: 'PARABRICKS_DEEPVARIANT' {
        container = "${params.sif_dir}/${params.parabricks_sif_name}"
        cpus      = 16
        memory    = 32.GB
    }
    withName: 'PARABRICKS_HAPLOTYPECALLER' {
        container = "${params.sif_dir}/${params.parabricks_sif_name}"
        cpus      = 16
        memory    = 24.GB
    }
    // 其他 Parabricks process 的 fallback
    withName: 'PARABRICKS.*' {
        container = "${params.sif_dir}/${params.parabricks_sif_name}"
    }

    // CNVkit：WGS 實測 10.4 GB
    withName: 'CNVKIT_BATCH' {
        container = "${params.sif_dir}/cnvkit_0.9.12.sif"
        cpus      = 8
        memory    = { task.attempt > 1 ? 16.GB : 12.GB }
    }

    // Delly：CPU-only，記憶體需求低
    withName: 'DELLY_GERMLINE' {
        container = "${params.sif_dir}/delly_1.7.3.sif"
        cpus      = 16
        memory    = 16.GB
    }

    // Manta（選用，--run_manta）：實測 1.9 GB
    withName: 'MANTA_GERMLINE' {
        container = "${params.sif_dir}/manta_1.6.0.sif"
        cpus      = 8
        memory    = 4.GB
    }

    // GangSTR per-chrom：CPU single-thread，24 個染色體平行執行
    // maxForks 控制同時跑幾條染色體，避免佔用太多 CPU
    withName: 'GANGSTR_CHROM' {
        container = "${params.sif_dir}/gangstr_2.5.0.sif"
        cpus      = 1
        memory    = 4.GB
        maxForks  = 8
    }

    // GangSTR merge：用 bcftools concat 合併 24 個 VCF
    withName: 'GANGSTR_MERGE' {
        container = "${params.sif_dir}/bcftools_1.23.1.sif"
        cpus      = 2
        memory    = 4.GB
    }

    // Mitochondria pipeline：個別設定（實測值 × 1.5 倍）
    withName: 'MITO_EXTRACT_READS' {
        container = "${params.sif_dir}/samtools_1.23.1.sif"
        cpus      = 2
        memory    = 1.GB
    }
    withName: 'MITO_BAM2FASTQ.*' {
        container = "${params.sif_dir}/samtools_1.23.1.sif"
        cpus      = 4
        memory    = 2.GB
    }
    withName: 'MITO_BWA_NORMAL' {
        container = "${params.sif_dir}/bwa_0.7.19.sif"
        cpus      = 4
        memory    = 2.GB
    }
    withName: 'MITO_BWA_SHIFTED' {
        container = "${params.sif_dir}/bwa_0.7.19.sif"
        cpus      = 4
        memory    = 2.GB
    }

    // MITO_SORT_MARKDUP 用 GATK Picard MarkDuplicates，alias 成 NORMAL/SHIFTED 兩路
    withName: 'MITO_SORT_INDEX_NORMAL' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        cpus      = 4
        memory    = { task.attempt > 1 ? 12.GB : 8.GB }
    }
    withName: 'MITO_SORT_INDEX_SHIFTED' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        cpus      = 4
        memory    = { task.attempt > 1 ? 12.GB : 8.GB }
    }
    withName: 'MITO_MUTECT2.*' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        cpus      = 4
        memory    = { task.attempt > 1 ? 10.GB : 6.GB }
    }
    withName: 'MITO_LIFTOVER' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        cpus      = 2
        memory    = 1.GB
    }
    withName: 'MITO_MERGE' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        cpus      = 2
        memory    = 1.GB
    }
    withName: 'MITO_FILTER' {
        container = "${params.sif_dir}/gatk_4.6.2.0.sif"
        cpus      = 2
        memory    = 2.GB
    }
}

// --- 報告設定 ---
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

report   { enabled = true; file = "${params.out_dir}/pipeline_info/execution_report_${trace_timestamp}.html" }
timeline { enabled = true; file = "${params.out_dir}/pipeline_info/execution_timeline_${trace_timestamp}.html" }
trace    { enabled = true; file = "${params.out_dir}/pipeline_info/execution_trace_${trace_timestamp}.txt" }